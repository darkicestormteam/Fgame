class_name WaveConfig extends Resource

# --- Основные настройки волны ---

## Время (в секундах от начала игры или предыдущей логики), когда эта волна должна начаться.
@export var activation_time: float = 0.0

## Сколько секунд будет длиться эта волна. 
## Если 0 — волна будет бесконечной, пока не будет остановлена вручную или следующей логикой.
@export var lifetime: float = 10.0

# --- Настройки спавна врагов ---

## Список сцен врагов, которые могут появляться в этой волне.
## Перетащите сюда .tscn файлы ваших врагов.
@export var enemy_scenes: Array[PackedScene] = []

## Веса вероятности появления для каждого врага из списка выше.
## Порядок должен совпадать с enemy_scenes. 
## Пример: [1, 3] означает, что второй враг будет появляться в 3 раза чаще первого.
## Если оставить пустым или количество не совпадет — шансы будут равными.
@export var spawn_weights: Array[int] = []

## Максимальное количество врагов этой волны, которые могут находиться на сцене одновременно.
## Спавн приостановится, если лимит достигнут.
@export var max_enemies: int = 10

## Задержка в секундах между попытками спавна очередного врага.
@export_range(0.1, 5.0, 0.1) var spawn_interval: float = 0.5

# --- Настройки позиции спавна ---

## Минимальное расстояние от края камеры, за которым должны появляться враги.
## Помогает спавнить врагов вне поля зрения игрока.
@export var min_distance_from_camera: float = 100.0

## Является ли эта волна босс-волной.
## Если true, следующая волна начнётся только после убийства всех врагов этой волны.
@export var is_boss_wave: bool = false
